{
  "title": "LLM Inference Overview",
  "uid": "llm-inference-overview",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": { "from": "now-15m", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "GPU Utilization (%)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "DCGM_FI_DEV_GPU_UTIL", "legendFormat": "gpu {{gpu}}" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "GPU Memory Used (MiB)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "DCGM_FI_DEV_FB_USED", "legendFormat": "gpu {{gpu}}" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Triton: Inference Requests / s",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "rate(nv_inference_request_success[1m])", "legendFormat": "{{model}}" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "GPU Power Draw (W)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "DCGM_FI_DEV_POWER_USAGE", "legendFormat": "gpu {{gpu}}" }
      ]
    }
  ]
}
